---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';
import type { BrewRatioCalculatorUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as BrewRatioCalculatorUI;
---

<div
  class="brew-calculator"
  data-phase-bloom={t.phaseBloomTemplate}
  data-phase-pour={t.phasePourTemplate}
  data-phase-iced={t.phaseIcedTemplate}
  data-cup-warning={t.cupWarningTemplate}
  data-fav-mode-coffee={t.favModeCoffee}
  data-fav-mode-water={t.favModeWater}
  data-fav-mode-iced={t.favModeIced}
  data-input-label-coffee={t.inputLabelCoffee}
  data-input-label-water={t.inputLabelWater}
  data-hot-water-label={t.resultHotWaterLabel}
  data-hot-water-iced-label={t.resultHotWaterIcedLabel}
>
  <div class="brew-card">
    <div class="brew-card-header"></div>
    <div class="brew-card-body">

      <div class="brew-mode-switcher">
        <button class="brew-mode-btn active" id="modeCoffee" type="button">
          <span class="brew-mode-icon"><Icon name="mdi:coffee" /></span>
          <span>{t.modeCoffee}</span>
          <span class="brew-mode-hint">{t.modeHintCoffee}</span>
        </button>
        <button class="brew-mode-btn" id="modeWater" type="button">
          <span class="brew-mode-icon"><Icon name="mdi:water-outline" /></span>
          <span>{t.modeWater}</span>
          <span class="brew-mode-hint">{t.modeHintWater}</span>
        </button>
      </div>

      <div class="brew-grid">
        <div>
          <div class="brew-section-label">
            <span class="brew-label-icon" id="inputIconCoffee"><Icon name="mdi:coffee" /></span>
            <span class="brew-label-icon brew-hidden" id="inputIconWater"><Icon name="mdi:water-outline" /></span>
            <span id="inputLabel">{t.inputLabelCoffee}</span>
          </div>
          <div class="brew-input-group">
            <input type="number" id="brewInput" class="brew-input" value="20" min="1" step="1" />
            <span class="brew-input-unit" id="inputUnit">g</span>
          </div>

          <div style="margin-top:1.5rem">
            <div class="brew-section-label">
              <Icon name="mdi:tune-variant" />
              {t.intensityLabel}
            </div>
            <div class="brew-intensity-grid">
              <button class="brew-intensity-btn" data-ratio-min="12" data-ratio-max="14" data-ratio-mid="13" type="button">
                <span class="brew-ratio-label">1:12-14</span>
                <span class="brew-intensity-name">{t.intensityStrong}</span>
              </button>
              <button class="brew-intensity-btn active" data-ratio-min="15" data-ratio-max="16" data-ratio-mid="15.5" type="button">
                <span class="brew-ratio-label">1:15-16</span>
                <span class="brew-intensity-name">{t.intensityBalanced}</span>
              </button>
              <button class="brew-intensity-btn" data-ratio-min="17" data-ratio-max="18" data-ratio-mid="17.5" type="button">
                <span class="brew-ratio-label">1:17-18</span>
                <span class="brew-intensity-name">{t.intensityLight}</span>
              </button>
              <button class="brew-intensity-btn" id="customRatioBtn" data-ratio-mid="0" type="button">
                <span class="brew-ratio-label">1:??</span>
                <span class="brew-intensity-name">{t.intensityCustom}</span>
              </button>
            </div>
            <div class="brew-custom-ratio" id="customRatioInputs">
              <div>
                <span class="brew-custom-label">{t.customCoffeeLabel}</span>
                <input type="number" id="customCoffee" class="brew-custom-input" value="1" min="1" step="0.5" />
              </div>
              <div class="brew-custom-sep">:</div>
              <div>
                <span class="brew-custom-label">{t.customWaterLabel}</span>
                <input type="number" id="customWater" class="brew-custom-input" value="15" min="1" step="0.5" />
              </div>
            </div>
          </div>

          <label class="brew-ice-toggle" id="iceToggleWrapper">
            <span class="brew-ice-label">
              <Icon name="mdi:snowflake" />
              {t.icedModeLabel}
            </span>
            <div class="brew-toggle">
              <input type="checkbox" id="iceToggle" />
              <span class="brew-toggle-slider"></span>
            </div>
          </label>
        </div>

        <div>
          <div class="brew-section-label">
            <Icon name="mdi:bullseye-arrow" />
            {t.recipeLabel}
          </div>
          <div class="brew-results-panel">
            <div class="brew-results-header">
              <span class="brew-results-title">{t.resultTitle}</span>
              <span class="brew-ratio-badge" id="ratioBadge">1:15.5</span>
            </div>
            <div class="brew-result-item">
              <div class="brew-result-left">
                <div class="brew-result-icon brew-icon-coffee"><Icon name="mdi:coffee" /></div>
                <div>
                  <div class="brew-result-name">{t.resultCoffeeLabel}</div>
                  <div class="brew-result-sub">{t.resultCoffeeSub}</div>
                </div>
              </div>
              <div class="brew-result-value" id="outCoffee">20<span>g</span></div>
            </div>
            <div class="brew-result-item" id="hotWaterRow">
              <div class="brew-result-left">
                <div class="brew-result-icon brew-icon-water"><Icon name="mdi:water-outline" /></div>
                <div>
                  <div class="brew-result-name" id="hotWaterLabel">{t.resultHotWaterLabel}</div>
                  <div class="brew-result-sub">{t.resultHotWaterSub}</div>
                </div>
              </div>
              <div class="brew-result-value" id="outWater">310<span>ml</span></div>
            </div>
            <div class="brew-result-item" id="iceRow" style="display:none">
              <div class="brew-result-left">
                <div class="brew-result-icon brew-icon-ice"><Icon name="mdi:snowflake" /></div>
                <div>
                  <div class="brew-result-name">{t.resultIceLabel}</div>
                  <div class="brew-result-sub">{t.resultIceSub}</div>
                </div>
              </div>
              <div class="brew-result-value" id="outIce">0<span>g</span></div>
            </div>
            <div class="brew-result-item brew-result-item-cup">
              <div class="brew-result-left">
                <div class="brew-result-icon brew-icon-cup"><Icon name="mdi:cup-outline" /></div>
                <div>
                  <div class="brew-result-name">{t.resultCupLabel}</div>
                  <div class="brew-result-sub">{t.resultCupSub}</div>
                </div>
              </div>
              <div class="brew-result-value brew-result-value-accent" id="outCup">278<span>ml</span></div>
            </div>
          </div>
          <div id="cupWarning" class="brew-cup-warning"></div>
          <div class="brew-phases" id="phasesSection">
            <div class="brew-phases-title">
              <Icon name="mdi:play-circle-outline" />
              {t.pouringGuideLabel}
            </div>
            <div class="brew-phase-list" id="phaseList"></div>
          </div>
        </div>
      </div>

      <div class="brew-favorites-section">
        <div class="brew-fav-header">
          <span class="brew-fav-title">
            <Icon name="mdi:star-outline" />
            {t.favoritesLabel}
          </span>
          <button class="brew-save-btn" id="saveRecipeBtn" type="button">{t.saveBtn}</button>
        </div>
        <div id="favList" class="brew-fav-list">
          <div class="brew-fav-empty" id="favEmpty">{t.favEmptyText}</div>
        </div>
      </div>
    </div>
  </div>

  <div class="brew-modal-overlay" id="saveModal">
    <div class="brew-modal">
      <div class="brew-modal-title">{t.modalTitle}</div>
      <input type="text" id="recipeNameInput" class="brew-modal-input" placeholder={t.modalPlaceholder} maxlength="40" />
      <div class="brew-modal-actions">
        <button class="brew-modal-cancel" id="cancelSaveBtn" type="button">{t.modalCancel}</button>
        <button class="brew-modal-confirm" id="confirmSaveBtn" type="button">{t.modalConfirm}</button>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    type BrewMode, type BrewState, type SavedRecipe,
    ICE_RATIO, BLOOM_WAIT_SECONDS,
    fillTemplate, loadRecipes, saveRecipes, computeBrewResult,
  } from './logic';

  const root = document.querySelector('.brew-calculator') as HTMLElement;
  const state: BrewState = { mode: 'coffee', inputValue: 20, ratio: 15.5, iceMode: false };

  function i(key: string): string { return root?.dataset[key] ?? ''; }
  function el(id: string): HTMLElement | null { return document.getElementById(id); }
  function setHTML(id: string, html: string) { const e = el(id); if (e) e.innerHTML = html; }
  function fmt(v: number): string { return v % 1 === 0 ? String(v) : v.toFixed(1); }
  function toggle(id: string, cls: string, active: boolean) { el(id)?.classList.toggle(cls, active); }

  function renderPhases(bloomMl: number, remainMl: number, hotWaterMl: number, iceMode: boolean) {
    const list = el('phaseList');
    if (!list) return;
    const phases = [
      fillTemplate(i('phaseBloom'), { bloomMl, bloomSeconds: BLOOM_WAIT_SECONDS }),
      fillTemplate(i('phasePour'), { hotWaterMl, pourCount: Math.ceil(remainMl / 50) }),
      ...(iceMode ? [fillTemplate(i('phaseIced'), { iceMl: Math.round(hotWaterMl * ICE_RATIO) })] : []),
    ];
    list.innerHTML = phases.map((text, idx) =>
      `<div class="brew-phase-item"><div class="brew-phase-number">${idx + 1}</div><div class="brew-phase-text">${text}</div></div>`
    ).join('');
  }

  function buildFavItem(r: SavedRecipe): HTMLElement {
    const modeLabel = r.mode === 'coffee' ? `${r.inputValue}${i('favModeCoffee')}` : `${r.inputValue}${i('favModeWater')}`;
    const item = document.createElement('div');
    item.className = 'brew-fav-item';
    item.dataset.id = r.id;
    item.innerHTML = `<span class="brew-fav-icon-dot"></span><div class="brew-fav-info"><div class="brew-fav-name">${r.name}</div><div class="brew-fav-meta">1:${r.ratio} &middot; ${modeLabel}${r.iceMode ? i('favModeIced') : ''}</div></div><button class="brew-fav-delete" data-id="${r.id}" type="button">&times;</button>`;
    return item;
  }

  function deleteRecipe(id: string) { saveRecipes(loadRecipes().filter((r) => r.id !== id)); renderFavorites(); }

  function loadRecipeIntoState(r: SavedRecipe) {
    Object.assign(state, { mode: r.mode, inputValue: r.inputValue, ratio: r.ratio, iceMode: r.iceMode });
    syncUIToState();
    render();
  }

  function renderFavorites() {
    const recipes = loadRecipes();
    const listEl = el('favList');
    const emptyEl = el('favEmpty');
    if (!listEl || !emptyEl) return;
    listEl.querySelectorAll('.brew-fav-item').forEach((e) => e.remove());
    emptyEl.style.display = recipes.length === 0 ? 'block' : 'none';
    recipes.forEach((r) => {
      const item = buildFavItem(r);
      item.addEventListener('click', (e) => { if (!(e.target as HTMLElement).classList.contains('brew-fav-delete')) loadRecipeIntoState(r); });
      item.querySelector('.brew-fav-delete')?.addEventListener('click', () => deleteRecipe(r.id));
      listEl.appendChild(item);
    });
  }

  function syncModeUI(isCoffee: boolean) {
    toggle('modeCoffee', 'active', isCoffee);
    toggle('modeWater', 'active', !isCoffee);
    const lbl = el('inputLabel'); const unit = el('inputUnit');
    if (lbl) lbl.textContent = isCoffee ? i('inputLabelCoffee') : i('inputLabelWater');
    if (unit) unit.textContent = isCoffee ? 'g' : 'ml';
    toggle('inputIconCoffee', 'brew-hidden', !isCoffee);
    toggle('inputIconWater', 'brew-hidden', isCoffee);
  }

  function syncIntensityUI() {
    let hasPreset = false;
    document.querySelectorAll('.brew-intensity-btn').forEach((btn) => {
      const mid = parseFloat((btn as HTMLElement).dataset.ratioMid ?? '0');
      const active = mid === state.ratio && btn.id !== 'customRatioBtn';
      btn.classList.toggle('active', active);
      if (active) hasPreset = true;
    });
    el('customRatioBtn')?.classList.toggle('active', !hasPreset);
    el('customRatioInputs')?.classList.toggle('visible', !hasPreset);
  }

  function syncUIToState() {
    const inp = el('brewInput') as HTMLInputElement;
    const tog = el('iceToggle') as HTMLInputElement;
    if (inp) inp.value = String(state.inputValue);
    if (tog) tog.checked = state.iceMode;
    syncModeUI(state.mode === 'coffee');
    syncIntensityUI();
  }

  function updateCupWarning(inCupMl: number) {
    const e = el('cupWarning');
    if (!e) return;
    const show = state.mode === 'water' && inCupMl < state.inputValue * 0.6;
    e.classList.toggle('visible', show);
    if (show) e.textContent = fillTemplate(i('cupWarning'), { inCupMl });
  }

  function render() {
    const res = computeBrewResult(state);
    setHTML('outCoffee', `${fmt(res.coffeeG)}<span>g</span>`);
    setHTML('outWater', `${res.hotWaterMl}<span>ml</span>`);
    setHTML('outIce', `${res.iceMl}<span>g</span>`);
    setHTML('outCup', `${res.inCupMl}<span>ml</span>`);
    const badge = el('ratioBadge'); if (badge) badge.textContent = `1:${fmt(state.ratio)}`;
    const iceRow = el('iceRow'); if (iceRow) iceRow.style.display = state.iceMode ? 'flex' : 'none';
    const hwl = el('hotWaterLabel'); if (hwl) hwl.textContent = state.iceMode ? i('hotWaterIcedLabel') : i('hotWaterLabel');
    updateCupWarning(res.inCupMl);
    renderPhases(res.bloomMl, res.remainMl, res.hotWaterMl, state.iceMode);
  }

  function updateCustomRatio() {
    const c = parseFloat((el('customCoffee') as HTMLInputElement)?.value ?? '1') || 1;
    const w = parseFloat((el('customWater') as HTMLInputElement)?.value ?? '15') || 15;
    state.ratio = Math.round((w / c) * 10) / 10;
    render();
  }

  function initModeButtons() {
    el('modeCoffee')?.addEventListener('click', () => { Object.assign(state, { mode: 'coffee' as BrewMode, inputValue: 20 }); syncUIToState(); render(); });
    el('modeWater')?.addEventListener('click', () => { Object.assign(state, { mode: 'water' as BrewMode, inputValue: 300 }); syncUIToState(); render(); });
    el('iceToggle')?.addEventListener('change', (e) => { state.iceMode = (e.target as HTMLInputElement).checked; render(); });
    el('brewInput')?.addEventListener('input', (e) => { state.inputValue = parseFloat((e.target as HTMLInputElement).value) || 1; render(); });
  }

  function initIntensityButtons() {
    const btns = document.querySelectorAll('.brew-intensity-btn');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        if (btn.id === 'customRatioBtn') { el('customRatioInputs')?.classList.add('visible'); updateCustomRatio(); return; }
        el('customRatioInputs')?.classList.remove('visible');
        state.ratio = parseFloat((btn as HTMLElement).dataset.ratioMid ?? '15.5');
        render();
      });
    });
    el('customCoffee')?.addEventListener('input', updateCustomRatio);
    el('customWater')?.addEventListener('input', updateCustomRatio);
  }

  function initModal() {
    const modal = el('saveModal');
    const nameInput = el('recipeNameInput') as HTMLInputElement;
    el('saveRecipeBtn')?.addEventListener('click', () => { if (nameInput) nameInput.value = ''; modal?.classList.add('visible'); nameInput?.focus(); });
    el('cancelSaveBtn')?.addEventListener('click', () => modal?.classList.remove('visible'));
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('visible'); });
    el('confirmSaveBtn')?.addEventListener('click', () => {
      const name = nameInput?.value.trim();
      if (!name) return;
      saveRecipes([{ id: Date.now().toString(), name, ...state }, ...loadRecipes()]);
      renderFavorites(); modal?.classList.remove('visible');
    });
    nameInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') el('confirmSaveBtn')?.click();
      if (e.key === 'Escape') modal?.classList.remove('visible');
    });
  }

  initModeButtons();
  initIntensityButtons();
  initModal();
  render();
  renderFavorites();
</script>

