---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';
import type { GrindConverterUI } from './ui';
import { GRIND_METHODS, GRINDERS } from './logic';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as GrindConverterUI;
---

<div
  class="grind-converter"
  data-unit-micras={t.unitMicras}
  data-unit-clicks={t.unitClicks}
  data-unit-level={t.unitLevel}
>
  <div class="grind-lab-wrapper">

    <div class="grind-lab-main">

      <header class="grind-interface-header">
        <label class="grind-control-label">{t.step1Label}</label>
        <select id="grinder-select" class="grind-custom-select">
          {GRINDERS.map((g) => (
            <option value={g.id}>{g.brand} {g.name}</option>
          ))}
        </select>
      </header>

      <div class="grind-method-selector">
        <label class="grind-control-label">{t.step2Label}</label>
        <div class="grind-tiles-grid">
          {GRIND_METHODS.map((m, idx) => (
            <button
              class="grind-method-tile"
              data-id={m.id}
              data-ref={t[`method${idx}Ref`]}
              data-desc={t[`method${idx}Desc`]}
              type="button"
            >
              <Icon name={m.icon} />
              <label>{t[`method${idx}Name`].split(' (')[0]}</label>
            </button>
          ))}
        </div>
      </div>

      <div class="grind-gauge">
        <label class="grind-control-label">{t.gaugeLabel}</label>
        <div class="grind-gauge-track">
          <div id="gauge-range" class="grind-gauge-range"></div>
        </div>
        <div class="grind-gauge-scale">
          <span>0μm</span>
          <span>400μm</span>
          <span>800μm</span>
          <span>1200μm</span>
          <span>1600μm</span>
        </div>
      </div>
    </div>

    <aside class="grind-sidebar">

      <div class="grind-result-header">
        <h3 id="target-name">--</h3>
      </div>

      <div class="grind-digital-readout">
        <span class="grind-value-large" id="main-value">--</span>
        <span class="grind-unit-label" id="unit-label">--</span>
      </div>

      <div class="grind-stats-row">
        <div class="grind-stat-node">
          <span class="grind-stat-label">{t.refLabel}</span>
          <span class="grind-stat-value" id="texture-text">--</span>
        </div>
        <div class="grind-stat-node">
          <span class="grind-stat-label">{t.rangeMicrasLabel}</span>
          <span class="grind-stat-value" id="size-text">--</span>
        </div>
      </div>

      <div class="grind-preview-section">
        <label class="grind-control-label grind-dist-label">{t.distributionLabel}</label>
        <div class="grind-texture-engine" id="particle-engine"></div>
      </div>

      <p id="method-info-text" class="grind-method-info"></p>

    </aside>

    <div class="grind-advice-section">
      <div class="grind-advice-card">
        <div class="grind-advice-header">
          <div class="grind-advice-icon grind-advice-icon-bitter">
            <Icon name="mdi:emoticon-confused-outline" />
          </div>
          <h4>{t.troubleIssue0}</h4>
        </div>
        <p>{t.troubleSolution0}</p>
        <div class="grind-tag-badge">{t.troubleAction0}</div>
      </div>

      <div class="grind-advice-card">
        <div class="grind-advice-header">
          <div class="grind-advice-icon grind-advice-icon-sour">
            <Icon name="mdi:emoticon-sad-outline" />
          </div>
          <h4>{t.troubleIssue1}</h4>
        </div>
        <p>{t.troubleSolution1}</p>
        <div class="grind-tag-badge">{t.troubleAction1}</div>
      </div>
    </div>

  </div>
</div>

<script>
  import { GRIND_METHODS, GRINDERS } from './logic';

  const root = document.querySelector('.grind-converter') as HTMLElement;
  const grinderSel = document.getElementById('grinder-select') as HTMLSelectElement;
  const tiles = document.querySelectorAll<HTMLButtonElement>('.grind-method-tile');

  function i(key: string): string { return root?.dataset[key] ?? ''; }
  function setText(id: string, txt: string): void { const el = document.getElementById(id); if (el) el.textContent = txt; }
  function getActiveTile(): HTMLButtonElement | null { return document.querySelector<HTMLButtonElement>('.grind-method-tile.active'); }
  function getActiveName(): string { return getActiveTile()?.querySelector('label')?.textContent?.toUpperCase() ?? ''; }
  function getTileAttr(attr: string): string { return getActiveTile()?.getAttribute(attr) ?? ''; }

  let activeId = 'v60';

  function getActiveGrinder() { return GRINDERS.find((g) => g.id === grinderSel.value); }
  function getActiveMethod() { return GRIND_METHODS.find((m) => m.id === activeId); }

  function getUnitLabel(grinder: (typeof GRINDERS)[0]): string {
    if (grinder.id === 'generic') return i('unitMicras');
    return i(grinder.type === 'clicks' ? 'unitClicks' : 'unitLevel');
  }

  function updateSidebar(method: (typeof GRIND_METHODS)[0], grinder: (typeof GRINDERS)[0]): void {
    setText('target-name', getActiveName());
    setText('main-value', grinder.ranges[method.id] ?? '--');
    setText('unit-label', getUnitLabel(grinder));
    setText('texture-text', getTileAttr('data-ref').toUpperCase());
    setText('size-text', `${method.minMicras} - ${method.maxMicras} μm`);
    setText('method-info-text', getTileAttr('data-desc'));
  }

  function updateGauge(method: (typeof GRIND_METHODS)[0]): void {
    const indicator = document.getElementById('gauge-range');
    if (!indicator) return;
    const startPct = (method.minMicras / 1600) * 100;
    const widthPct = Math.max(3, ((method.maxMicras - method.minMicras) / 1600) * 100);
    indicator.style.left = `${startPct}%`;
    indicator.style.width = `${widthPct}%`;
    indicator.setAttribute('data-micras', `${method.minMicras}-${method.maxMicras}μm`);
  }

  function buildParticle(baseSize: number, uniformity: number): HTMLDivElement {
    const p = document.createElement('div');
    p.className = 'grind-particle';
    const spread = (1 - uniformity) * 2;
    const s = Math.max(1, baseSize * (1 + (Math.random() - 0.5) * spread));
    p.style.width = `${s}px`;
    p.style.height = `${s}px`;
    p.style.opacity = String(Math.random() * 0.3 + 0.6);
    p.style.transform = `rotate(${Math.random() * 360}deg)`;
    return p;
  }

  function updateParticles(method: (typeof GRIND_METHODS)[0], grinder: (typeof GRINDERS)[0]): void {
    const engine = document.getElementById('particle-engine');
    if (!engine) return;
    engine.innerHTML = '';
    const avgMicras = (method.minMicras + method.maxMicras) / 2;
    const baseSize = Math.max(2, (avgMicras / 1600) * 25);
    for (let k = 0; k < 120; k++) {
      engine.appendChild(buildParticle(baseSize, grinder.uniformity));
    }
  }

  function refresh(): void {
    const grinder = getActiveGrinder();
    const method = getActiveMethod();
    if (!grinder || !method) return;
    tiles.forEach((t) => t.classList.toggle('active', t.getAttribute('data-id') === activeId));
    updateSidebar(method, grinder);
    updateGauge(method);
    updateParticles(method, grinder);
  }

  function initTiles(): void {
    tiles.forEach((tile) => {
      tile.addEventListener('click', () => {
        const id = tile.getAttribute('data-id');
        if (id) { activeId = id; refresh(); }
      });
    });
  }

  function init(): void {
    grinderSel?.addEventListener('change', refresh);
    initTiles();
    refresh();
  }

  init();
</script>

