---
import { Icon } from 'astro-icon/components';
import type { KnownLocale } from '../../types';
import type { CoffeeTimerUI } from './ui';

interface Props {
  locale?: KnownLocale;
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as CoffeeTimerUI;
---

<div
  class="coffee-timer"
  data-ready-text={t.readyText}
  data-instruction-start={t.instructionStart}
  data-hint-start={t.hintStart}
  data-phase1-label={t.phase1Label}
  data-phase2-label={t.phase2Label}
  data-phase3-label={t.phase3Label}
  data-instruction-bloom={t.instructionBloom}
  data-hint-bloom={t.hintBloom}
  data-instruction-pour={t.instructionPour}
  data-hint-pour={t.hintPour}
  data-instruction-drain={t.instructionDrain}
  data-hint-drain={t.hintDrain}
  data-pause-btn={t.pauseBtn}
  data-resume-btn={t.resumeBtn}
>
  <div class="timer-card">
    <div class="timer-phase-indicator">
      <div id="progressBar" class="timer-progress-bar"></div>
    </div>

    <div class="timer-display">
      <div id="timeDisplay" class="timer-time">00:00</div>
      <div id="phaseDisplay" class="timer-phase-name">{t.readyText}</div>
    </div>

    <div class="timer-target-display">
      <div class="target-label">{t.targetLabel}</div>
      <div class="target-value"><span id="targetWeightDisplay">300</span><span class="target-unit">g</span></div>
    </div>

    <div class="timer-instruction-box">
      <div id="instructionText" class="instruction-text">{t.instructionStart}</div>
      <div id="instructionHint" class="instruction-hint">{t.hintStart}</div>
    </div>

    <div class="timer-controls">
      <button id="startBtn" class="main-start-btn" type="button">
        <Icon name="mdi:play" />
        <span>{t.startBtn}</span>
      </button>

      <div id="secondaryActions" class="secondary-controls">
        <button id="pauseBtn" class="control-btn btn-pause" type="button">
          <Icon name="mdi:pause" id="pauseIcon" />
          <Icon name="mdi:play" id="playIcon" class="timer-hidden" />
          <span id="pauseText">{t.pauseBtn}</span>
        </button>
        <button id="resetBtn" class="control-btn btn-reset" type="button">
          <Icon name="mdi:refresh" />
          <span>{t.resetBtn}</span>
        </button>
      </div>
    </div>

    <div id="summaryOverlay" class="summary-overlay">
      <div class="summary-title">{t.summaryTitle}</div>
      <div id="summaryMessage" class="instruction-hint">{t.summaryMessage}</div>

      <div class="summary-stats">
        <div class="stat-box">
          <span class="stat-label">{t.statTimeLabel}</span>
          <span id="statTime" class="stat-value">00:00</span>
        </div>
        <div class="stat-box">
          <span class="stat-label">{t.statWaterLabel}</span>
          <span id="statWater" class="stat-value">300g</span>
        </div>
      </div>

      <button id="closeSummaryBtn" class="close-summary-btn" type="button">{t.newBrewBtn}</button>
    </div>

    <div class="timer-setup" id="setupSection">
      <div class="setup-title">{t.setupTitle}</div>
      <div class="setup-grid">
        <div class="input-group">
          <label class="input-label">{t.labelWater}</label>
          <input type="number" id="inputWater" class="setup-input" value="300" min="50" step="10" />
        </div>
        <div class="input-group">
          <label class="input-label">{t.labelBloomWater}</label>
          <input type="number" id="inputBloomWater" class="setup-input" value="60" min="10" step="5" />
        </div>
        <div class="input-group">
          <label class="input-label">{t.labelBloomTime}</label>
          <input type="number" id="inputBloomTime" class="setup-input" value="30" min="10" />
        </div>
        <div class="input-group">
          <label class="input-label">{t.labelTotalTime}</label>
          <input type="number" id="inputTotalTime" class="setup-input" value="180" min="60" />
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    type TimerConfig, type TimerPhase,
    DEFAULT_CONFIG, BEEP_WARN_SECONDS,
    computePhase, formatTime, fillTemplate,
  } from './logic';

  const root = document.querySelector('.coffee-timer') as HTMLElement;
  const config: TimerConfig = { ...DEFAULT_CONFIG };

  let startTime = 0;
  let pausedTime = 0;
  let animationId = 0;
  let isRunning = false;
  let isPaused = false;
  let lastBeepSecond = -1;
  let soundCtx: AudioContext | null = null;

  function i(key: string): string { return root?.dataset[key] ?? ''; }
  function el(id: string): HTMLElement | null { return document.getElementById(id); }
  function setText(id: string, text: string) { const e = el(id); if (e) e.textContent = text; }
  function addClass(id: string, cls: string) { el(id)?.classList.add(cls); }
  function rmClass(id: string, cls: string) { el(id)?.classList.remove(cls); }
  function toggle(id: string, cls: string, active: boolean) { el(id)?.classList.toggle(cls, active); }

  function beep() {
    if (!soundCtx) soundCtx = new AudioContext();
    const osc = soundCtx.createOscillator();
    const gain = soundCtx.createGain();
    osc.connect(gain);
    gain.connect(soundCtx.destination);
    osc.type = 'sine';
    osc.frequency.setValueAtTime(880, soundCtx.currentTime);
    gain.gain.setValueAtTime(0, soundCtx.currentTime);
    gain.gain.linearRampToValueAtTime(0.1, soundCtx.currentTime + 0.01);
    gain.gain.linearRampToValueAtTime(0, soundCtx.currentTime + 0.1);
    osc.start();
    osc.stop(soundCtx.currentTime + 0.1);
  }

  function haptic() { if ('vibrate' in navigator) navigator.vibrate(100); }

  function setProgress(cls: TimerPhase, pct: number) {
    const bar = el('progressBar');
    if (!bar) return;
    bar.className = `timer-progress-bar ${cls}`;
    bar.style.width = `${pct}%`;
  }

  function setPhaseTexts(label: string, instruction: string, hint: string) {
    setText('phaseDisplay', label);
    setText('instructionText', instruction);
    setText('instructionHint', hint);
  }

  function renderBloom(pct: number, currentSecond: number) {
    setProgress('bloom', pct);
    setPhaseTexts(
      i('phase1Label'),
      fillTemplate(i('instructionBloom'), { bloomWater: config.bloomWater }),
      i('hintBloom'),
    );
    if (currentSecond === config.bloomSeconds - BEEP_WARN_SECONDS && lastBeepSecond !== currentSecond) {
      beep(); haptic(); lastBeepSecond = currentSecond;
    }
  }

  function renderPour(pct: number) {
    setProgress('pour', pct);
    setPhaseTexts(
      i('phase2Label'),
      fillTemplate(i('instructionPour'), { waterTotal: config.waterTotal }),
      i('hintPour'),
    );
  }

  function renderDrain(pct: number) {
    setProgress('drain', pct);
    setPhaseTexts(i('phase3Label'), i('instructionDrain'), i('hintDrain'));
  }

  function updateDisplay(elapsed: number) {
    setText('timeDisplay', formatTime(elapsed));
    const result = computePhase(elapsed, config);
    const sec = Math.floor(elapsed);
    if (result.phase === 'bloom') renderBloom(result.progress, sec);
    else if (result.phase === 'pour') renderPour(result.progress);
    else renderDrain(result.progress);
  }

  const tick = () => {
    if (!isRunning || isPaused) return;
    const elapsed = (performance.now() - startTime) / 1000;
    updateDisplay(elapsed);
    if (elapsed < config.totalSeconds) {
      animationId = requestAnimationFrame(tick);
    } else {
      complete();
    }
  };

  function startTimer() {
    if (isRunning) return;
    isRunning = true;
    isPaused = false;
    startTime = performance.now();
    pausedTime = 0;
    addClass('startBtn', 'timer-hidden');
    addClass('secondaryActions', 'visible');
    addClass('setupSection', 'timer-hidden');
    tick();
  }

  function togglePause() {
    if (!isRunning) return;
    isPaused = !isPaused;
    toggle('pauseBtn', 'active', isPaused);
    toggle('pauseIcon', 'timer-hidden', isPaused);
    toggle('playIcon', 'timer-hidden', !isPaused);
    setText('pauseText', isPaused ? i('resumeBtn') : i('pauseBtn'));
    if (isPaused) {
      pausedTime = performance.now() - startTime;
      cancelAnimationFrame(animationId);
    } else {
      startTime = performance.now() - pausedTime;
      tick();
    }
  }

  function resetTimer() {
    cancelAnimationFrame(animationId);
    isRunning = false;
    isPaused = false;
    startTime = 0;
    setText('timeDisplay', '00:00');
    setText('phaseDisplay', i('readyText'));
    setText('instructionText', i('instructionStart'));
    setText('instructionHint', i('hintStart'));
    const bar = el('progressBar');
    if (bar) { bar.style.width = '0%'; bar.className = 'timer-progress-bar'; }
    rmClass('startBtn', 'timer-hidden');
    rmClass('secondaryActions', 'visible');
    rmClass('setupSection', 'timer-hidden');
    rmClass('pauseBtn', 'active');
  }

  function complete() {
    isRunning = false;
    const timeEl = el('timeDisplay');
    const statTime = el('statTime'); if (statTime && timeEl) statTime.textContent = timeEl.textContent;
    setText('statWater', `${config.waterTotal}g`);
    addClass('summaryOverlay', 'visible');
    beep(); beep();
  }

  function closeSummary() {
    rmClass('summaryOverlay', 'visible');
    resetTimer();
  }

  function setInput(id: string, val: number): void {
    const inp = el(id) as HTMLInputElement;
    if (inp) inp.value = String(val);
  }

  function clampBloomWater(): void {
    const max = Math.max(10, Math.round(config.waterTotal * 0.15));
    if (config.bloomWater <= max) return;
    config.bloomWater = max;
    setInput('inputBloomWater', max);
  }

  function clampBloomTime(): void {
    const max = config.totalSeconds - 30;
    if (config.bloomSeconds <= max) return;
    config.bloomSeconds = Math.max(10, max);
    setInput('inputBloomTime', config.bloomSeconds);
  }

  function scaleTimeToWater(oldWater: number, newWater: number): void {
    if (oldWater <= 0) return;
    const scaled = Math.max(60, Math.round(config.totalSeconds * newWater / oldWater));
    config.totalSeconds = scaled;
    setInput('inputTotalTime', scaled);
  }

  function handleInput(id: string, value: string): void {
    const val = parseInt(value) || 0;
    if (id === 'inputWater') {
      const old = config.waterTotal;
      config.waterTotal = val;
      setText('targetWeightDisplay', String(val));
      scaleTimeToWater(old, val);
      clampBloomWater();
    }
    if (id === 'inputBloomWater') { config.bloomWater = val; clampBloomWater(); }
    if (id === 'inputBloomTime') { config.bloomSeconds = val; clampBloomTime(); }
    if (id === 'inputTotalTime') { config.totalSeconds = val; clampBloomTime(); }
  }

  function initButtons() {
    el('startBtn')?.addEventListener('click', startTimer);
    el('pauseBtn')?.addEventListener('click', togglePause);
    el('resetBtn')?.addEventListener('click', resetTimer);
    el('closeSummaryBtn')?.addEventListener('click', closeSummary);
  }

  function initInputs() {
    ['inputWater', 'inputBloomWater', 'inputBloomTime', 'inputTotalTime'].forEach((id) => {
      el(id)?.addEventListener('input', (e) => handleInput(id, (e.target as HTMLInputElement).value));
    });
  }

  initButtons();
  initInputs();
</script>

